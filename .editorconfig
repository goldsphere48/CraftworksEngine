root = true

# All
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true

# C/C++
[*.{c,cpp,h,hpp}]
indent_style = space
indent_size  = 4

# CMake
[CMakeLists.txt]
indent_style = space
indent_size  = 4

[*.cmake]
indent_style = space
indent_size  = 4

# ── Batch / Shell ─────────────────────────────────────────────────────────
[*.bat]
end_of_line  = crlf
indent_style = space
indent_size  = 4

[*.sh]
indent_style = space
indent_size  = 4
